---
import Header from "../components/company/CompanyHeader.astro";
import Footer from "../components/company/CompanyFooter.astro";

// Verileri doğrudan büyük harf ve standart 'I' ile güncelledik
const apps = [
  { name: "PEXA AI", desc: "Advanced generative AI for professional visuals.", link: "/pexa", tag: "AI TOOL" },
  { name: "STRUX", desc: "Transforming ideas into native iOS applications.", link: "/strux", tag: "BUILDER" },
  { name: "MAX ON THE ISLAND", desc: "Logic-based puzzle adventure with environmental mechanics.", link: "/maxontheisland", tag: "GAME" },
  { name: "MAX ON THE SPACE", desc: "Physics-based puzzles in zero gravity environments.", link: "/maxonthespace", tag: "GAME" },
  { name: "IMPOSTERX", desc: "Multiplayer social deduction and strategy platform.", link: "/imposterx", tag: "SOCIAL" },
  { name: "CITYGUESSR", desc: "Interactive geographic exploration using global map data.", link: "/cityguessr", tag: "TRIVIA" },
  { name: "COUNTRYGUESSR", desc: "Test global knowledge with flags, capitals and borders.", link: "/countryguessr", tag: "TRIVIA" },
  { name: "FLAGGUESSR", desc: "Visual challenge combining flag ID with map outlines.", link: "/flagguessr", tag: "TRIVIA" },
  { name: "WORD CHAIN X", desc: "Cognitive flexibility through linguistic word chains.", link: "/wordchainx", tag: "PUZZLE" },
];
---

<html lang="en"> <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Ashak Studios</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;700;800&display=swap" rel="stylesheet">

    <style>
      :root {
        --color-bg: #000000;
        --color-text: #FFFFFF;
        --color-muted: #888888;
      }

      body {
        margin: 0;
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: 'Raleway', sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      .main-content {
        padding: 160px 40px 100px;
        max-width: 1400px;
        margin: 0 auto;
      }

      .hero-title {
        font-size: clamp(60px, 10vw, 120px);
        font-weight: 800;
        line-height: 0.9;
        letter-spacing: -4px;
        margin-bottom: 20px;
        /* text-transform: uppercase; gereksiz hale geldi ama güvenlik için kalabilir */
      }

      .section-label {
        font-size: 24px;
        font-weight: 300;
        color: var(--color-muted);
        margin-bottom: 80px;
        display: block;
      }

      .apps-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
        gap: 60px 40px;
      }

      .app-item {
        border-top: 1px solid #333;
        padding-top: 30px;
        text-decoration: none;
        color: white;
        transition: border-color 0.3s;
      }

      .app-item:hover {
        border-top-color: #FFF;
      }

      .app-tag {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        color: var(--color-muted);
        margin-bottom: 12px;
        display: block;
      }

      .app-name {
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 12px;
        letter-spacing: -1px;
      }

      .app-description {
        font-size: 16px;
        color: var(--color-muted);
        line-height: 1.5;
        max-width: 340px;
      }

      @media (max-width: 768px) {
        .main-content { padding: 120px 20px 60px; }
        .hero-title { letter-spacing: -2px; }
        .apps-grid { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>

    <Header />

    <main class="main-content">
      <h1 class="hero-title">ASHAK<br/>STUDIOS</h1>
      <span class="section-label">Apps</span>

      <div class="apps-grid">
        {apps.map(app => (
          <a href={app.link} class="app-item">
            <span class="app-tag">{app.tag}</span>
            <div class="app-name">{app.name}</div>
            <p class="app-description">{app.desc}</p>
          </a>
        ))}
      </div>
    </main>

    <Footer />

  </body>
</html>