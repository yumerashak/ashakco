---
import Header from "../../components/company/CompanyHeader.astro";
import Footer from "../../components/company/CompanyFooter.astro";

const EFFECTIVE_DATE = "November 10, 2025";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LEGAL PROTOCOLS | CITYGUESSR</title>
    <meta name="description" content="Privacy Policy and Terms of Service for CityGuessr." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;700;800&display=swap" rel="stylesheet">

    <style>
      :root {
        --color-bg: #000000;
        --color-text: #FFFFFF;
        --color-muted: #888888;
        --color-border: #222222;
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }

      body {
        margin: 0;
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: 'Raleway', sans-serif;
        -webkit-font-smoothing: antialiased;
        line-height: 1.6;
      }

      .container { max-width: 1000px; margin: 0 auto; padding: 0 40px; }

      /* --- HERO --- */
      .hero {
        padding: 160px 0 60px;
        border-bottom: 1px solid var(--color-border);
      }
      
      .date-badge {
        font-size: 12px;
        letter-spacing: 2px;
        color: var(--color-muted);
        text-transform: uppercase;
        font-weight: 700;
        display: block;
        margin-bottom: 20px;
      }

      .hero h1 {
        font-size: clamp(50px, 8vw, 90px);
        font-weight: 800;
        letter-spacing: -4px;
        line-height: 0.9;
        margin: 0;
        text-transform: uppercase;
      }

      /* TOC */
      .toc { display: flex; gap: 30px; margin-top: 40px; }
      .toc-link {
        color: var(--color-text);
        text-decoration: none;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        transition: opacity 0.3s;
      }
      .toc-link:hover { opacity: 0.5; }

      /* --- CONTENT --- */
      .legal-content { padding: 40px 0 100px; }

      .legal-card {
        padding: 80px 0;
        border-bottom: 1px solid var(--color-border);
        scroll-margin-top: 100px;
      }

      .section-title {
        font-size: 42px;
        font-weight: 800;
        letter-spacing: -1px;
        margin: 0 0 40px;
        text-transform: uppercase;
      }
      
      .meta-info {
        font-size: 14px; 
        color: var(--color-muted);
        display: block; 
        margin-bottom: 40px;
      }

      h3 { 
        font-size: 18px; 
        font-weight: 700;
        color: #FFF; 
        margin: 40px 0 20px; 
        letter-spacing: 1px;
        text-transform: uppercase;
      }

      p, li { 
        font-size: 17px; 
        color: var(--color-muted); 
        margin-bottom: 20px;
        font-weight: 400;
      }

      ul { margin: 0 0 30px; padding-left: 20px; }
      li { margin-bottom: 12px; }
      
      a { color: #FFF; text-decoration: underline; transition: opacity 0.3s; }
      a:hover { opacity: 0.7; }

      /* Highlight Box */
      .highlight-box {
        background: #0A0A0A;
        border: 1px solid var(--color-border);
        padding: 30px;
        margin: 40px 0;
        border-left: 4px solid #FFF;
      }
      .highlight-box h3 { margin-top: 0; font-size: 14px; }
      .highlight-box p { color: #EEE; font-size: 16px; margin: 0; }

      @media(max-width: 768px) {
        .container { padding: 0 20px; }
        .hero { padding: 120px 0 40px; }
        .section-title { font-size: 32px; }
      }
    </style>
  </head>
  <body>

    <Header />

    <main class="container">
      
      <section class="hero">
        <span class="date-badge">EFFECTIVE: {EFFECTIVE_DATE}</span>
        <h1>LEGAL<br/>PROTOCOLS</h1>
        
        <nav class="toc">
          <a class="toc-link" href="#privacy">Privacy Policy</a>
          <a class="toc-link" href="#terms">Terms of Service</a>
        </nav>
      </section>

      <div class="legal-content">
        <article id="privacy" class="legal-card">
          <h2 class="section-title">Privacy Policy</h2>
          <span class="meta-info">Applies to: “CityGuessr” for iOS and Android.</span>

          <h3>1) Summary</h3>
          <p>CityGuessr is designed to be private. We do not run player accounts and we do not collect or store personal data on our servers. App preferences are stored locally on your device.</p>

          <div class="highlight-box">
            <h3>ZERO ADS & NO TRACKING</h3>
            <p>CityGuessr has <strong>NO advertisements</strong> and uses <strong>NO tracking analytics</strong>. It is a clean, premium-feel experience available for free.</p>
          </div>

          <h3>2) Data We Do <em>Not</em> Collect</h3>
          <ul>
            <li>No names, emails, or phone numbers.</li>
            <li>No precise GPS location.</li>
            <li>No ad SDKs or marketing trackers.</li>
          </ul>

          <h3>3) Purchases (Donations)</h3>
          <p>We offer optional "Support" purchases. These are voluntary donations and do not unlock features. Payments are processed by Apple/Google. We do not see your financial info.</p>

          <h3>4) Children’s Privacy</h3>
          <p>Safe for all ages. If under age, please use with parental guidance for any purchases.</p>

          <h3>5) Contact</h3>
          <p>Questions? <a href="mailto:contact@ashak.co">contact@ashak.co</a>.</p>
        </article>

        <article id="terms" class="legal-card">
          <h2 class="section-title">Terms of Service</h2>
          <span class="meta-info">Effective Date: {EFFECTIVE_DATE}</span>

          <h3>1) License</h3>
          <p>We grant you a personal, non-exclusive license for entertainment purposes only.</p>

          <h3>2) No Ads</h3>
          <p>CityGuessr is ad-free and will remain so for the best user experience.</p>

          <h3>3) Purchases</h3>
          <p>Optional donations only. No subscriptions. Refunds managed by platform.</p>

          <h3>4) Connectivity</h3>
          <p>Internet needed for map data and purchase validation.</p>

          <h3>5) Liability</h3>
          <p>Provided “as is”. No warranties implied.</p>

          <h3>6) Contact</h3>
          <p>Support: <a href="mailto:contact@ashak.co">contact@ashak.co</a></p>
        </article>
      </div>

    </main>

    <Footer />
  </body>
</html>