---
import Header from "../components/company/CompanyHeader.astro";
import Footer from "../components/company/CompanyFooter.astro";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>THE STUDIO | ASHAK STUDIOS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;700;800&display=swap" rel="stylesheet">

    <style>
      :root {
        --color-bg: #000000;
        --color-text: #FFFFFF;
        --color-muted: #888888;
        --color-border: #333333;
      }

      body {
        margin: 0;
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: 'Raleway', sans-serif;
        -webkit-font-smoothing: antialiased;
        line-height: 1.6;
      }

      .main-content {
        padding: 160px 40px 100px;
        max-width: 1400px;
        margin: 0 auto;
      }

      .hero-title {
        font-size: clamp(60px, 10vw, 120px);
        font-weight: 800;
        line-height: 0.9;
        letter-spacing: -4px;
        margin-bottom: 20px;
        text-transform: uppercase;
      }

      .section-label {
        font-size: 24px;
        font-weight: 300;
        color: var(--color-muted);
        margin-bottom: 80px;
        display: block;
      }

      /* --- CONTENT GRID --- */
      .about-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 80px;
        border-top: 1px solid var(--color-border);
        padding-top: 80px;
      }

      .about-text h2 {
        font-size: 42px;
        font-weight: 700;
        letter-spacing: -1px;
        margin-bottom: 40px;
        text-transform: uppercase;
      }

      .about-text p {
        font-size: 18px;
        color: var(--color-muted);
        margin-bottom: 32px;
        max-width: 600px;
        line-height: 1.8;
      }

      /* --- STATS SECTION --- */
      .stats-list {
        display: flex;
        flex-direction: column;
        gap: 0;
      }

      .stat-item {
        border-bottom: 1px solid var(--color-border);
        padding: 40px 0;
        transition: border-color 0.3s;
      }

      .stat-item:first-child { border-top: 1px solid var(--color-border); }

      .stat-item:hover {
        border-color: #FFFFFF;
      }

      .stat-number {
        font-size: 48px;
        font-weight: 800;
        display: block;
        letter-spacing: -2px;
        margin-bottom: 8px;
      }

      .stat-label {
        font-size: 11px;
        font-weight: 700;
        color: var(--color-muted);
        text-transform: uppercase;
        letter-spacing: 2px;
      }

      /* --- CTA LINK --- */
      .btn-text {
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 1px;
        color: #FFFFFF;
        text-decoration: none;
        border-bottom: 2px solid #FFFFFF;
        padding-bottom: 4px;
        text-transform: uppercase;
        transition: opacity 0.3s;
        display: inline-block;
        margin-top: 20px;
      }

      .btn-text:hover { opacity: 0.5; }

      @media (max-width: 1024px) {
        .about-grid { grid-template-columns: 1fr; gap: 60px; }
        .hero-title { letter-spacing: -2px; }
        .main-content { padding: 120px 20px 60px; }
      }
    </style>
  </head>
  <body>
    
    <Header />

    <main class="main-content">
      <h1 class="hero-title">THE<br/>STUDIO.</h1>
      <span class="section-label">Behind the pixels, code, and interfaces</span>

      <div class="about-grid">
        
        <div class="about-text">
          <h2>REFINED SIMPLICITY.</h2>
          <p>
            Founded in 2024, Ashak Studios is an independent technology company driven by a single principle: software should be quiet, capable, and respectful of the user.
          </p>
          <p>
            We moved away from the chaotic noise of modern app development to focus on clear, functional, and user-respecting software. Whether it's a utility tool like Pexa or an interactive experience like the Max series, our code is clean and our design is intentional.
          </p>
          <p>
            Based in Istanbul, we operate at the intersection of mobile innovation and creative design, delivering products that millions of users rely on daily.
          </p>
          <a href="/contact" class="btn-text">Contact Us</a>
        </div>

        <div class="stats-list">
          <div class="stat-item">
            <span class="stat-number">2024</span>
            <span class="stat-label">ESTABLISHED</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">9+</span>
            <span class="stat-label">PUBLISHED APPS</span>
          </div>
          <div class="stat-item">
            <span class="stat-number">ISTANBUL</span>
            <span class="stat-label">HQ & DEVELOPMENT</span>
          </div>
        </div>

      </div>
    </main>

    <Footer />
  </body>
</html>