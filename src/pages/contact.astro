---
import Header from "../components/company/CompanyHeader.astro";
import Footer from "../components/company/CompanyFooter.astro";

const SUPPORT_EMAIL = "contact@ashak.co";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CONTACT | ASHAK STUDIOS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;700;800&display=swap" rel="stylesheet">

    <style>
      :root {
        --color-bg: #000000;
        --color-text: #FFFFFF;
        --color-muted: #888888;
        --color-border: #333333;
      }

      body {
        margin: 0;
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: 'Raleway', sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      .main-content {
        padding: 160px 40px 100px;
        max-width: 1400px;
        margin: 0 auto;
      }

      .hero-title {
        font-size: clamp(60px, 10vw, 120px);
        font-weight: 800;
        line-height: 0.9;
        letter-spacing: -4px;
        margin-bottom: 20px;
        text-transform: uppercase;
      }

      .section-label {
        font-size: 24px;
        font-weight: 300;
        color: var(--color-muted);
        margin-bottom: 80px;
        display: block;
      }

      .contact-layout {
        display: grid;
        grid-template-columns: 1fr 1.5fr;
        gap: 80px;
        border-top: 1px solid var(--color-border);
        padding-top: 60px;
      }

      /* --- INFO SIDE --- */
      .info-side {
        display: flex;
        flex-direction: column;
        gap: 60px;
      }

      .info-block h3 {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 2px;
        color: var(--color-muted);
        text-transform: uppercase;
        margin-bottom: 20px;
      }

      .info-link {
        font-size: 24px;
        font-weight: 400;
        color: #FFF;
        text-decoration: none;
        display: block;
        margin-bottom: 10px;
        transition: opacity 0.3s;
      }
      .info-link:hover { opacity: 0.6; }

      /* --- FORM SIDE --- */
      .form-side {
        display: flex;
        flex-direction: column;
      }

      .input-group {
        margin-bottom: 40px;
      }

      label {
        display: block;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        color: var(--color-muted);
        text-transform: uppercase;
        margin-bottom: 12px;
      }

      input, textarea {
        width: 100%;
        background: transparent;
        border: none;
        border-bottom: 1px solid var(--color-border);
        padding: 12px 0;
        color: #FFF;
        font-family: 'Raleway', sans-serif;
        font-size: 18px;
        transition: border-color 0.3s;
        border-radius: 0;
      }

      input:focus, textarea:focus {
        outline: none;
        border-bottom-color: #FFF;
      }

      textarea {
        min-height: 120px;
        resize: none;
      }

      .actions {
        margin-top: 20px;
        display: flex;
        gap: 32px;
        align-items: center;
      }

      .btn-text {
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 1px;
        color: #FFF;
        text-decoration: none;
        border-bottom: 1px solid #FFF;
        text-transform: uppercase;
        cursor: pointer;
        padding-bottom: 2px;
        transition: opacity 0.3s;
        background: transparent;
        border-top: none; border-left: none; border-right: none;
      }

      .btn-text:hover { opacity: 0.5; }

      /* --- TOAST --- */
      .toast {
        position: fixed;
        bottom: 40px;
        left: 40px;
        background: #FFF;
        color: #000;
        padding: 12px 24px;
        font-size: 12px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        transform: translateY(100px);
        opacity: 0;
        transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1);
        z-index: 2000;
      }
      .toast.show { transform: translateY(0); opacity: 1; }

      @media (max-width: 900px) {
        .contact-layout { grid-template-columns: 1fr; gap: 60px; }
        .main-content { padding: 120px 20px 60px; }
        .hero-title { letter-spacing: -2px; }
        .info-link { font-size: 20px; }
      }
    </style>
  </head>
  <body>

    <Header />

    <main class="main-content">
      <h1 class="hero-title">GET IN<br/>TOUCH.</h1>
      <span class="section-label">Contact</span>

      <div class="contact-layout">
        
        <aside class="info-side">
          <div class="info-block">
            <h3>Direct Contact</h3>
            <a href={`mailto:${SUPPORT_EMAIL}`} class="info-link">{SUPPORT_EMAIL}</a>
            <button id="btn-copy" class="btn-text" style="font-size: 11px;">Copy Email Address</button>
          </div>

          <div class="info-block">
            <h3>Headquarters</h3>
            <p class="info-link" style="cursor: default;">Istanbul, TR / Remote</p>
          </div>
        </aside>

        <div class="form-side">
          <form id="contact-form">
            <div class="input-group">
              <label for="name">Your Name</label>
              <input id="name" type="text" required placeholder="Your Name" />
            </div>

            <div class="input-group">
              <label for="email">Email Address</label>
              <input id="email" type="email" required placeholder="yourname@example.com" />
            </div>

            <div class="input-group">
              <label for="subject">Subject</label>
              <input id="subject" type="text" placeholder="Inquiry" />
            </div>

            <div class="input-group">
              <label for="message">Message</label>
              <textarea id="message" required placeholder="How can we help you?"></textarea>
            </div>

            <div class="actions">
              <button type="submit" class="btn-text">Send Message</button>
            </div>
          </form>
        </div>

      </div>
    </main>

    <Footer />

    <div id="toast" class="toast">Action completed</div>

    <script is:inline define:vars={{ SUPPORT_EMAIL }}>
      const form = document.getElementById('contact-form');
      const copyBtn = document.getElementById('btn-copy');
      const toast = document.getElementById('toast');

      function showToast(msg) {
        toast.textContent = msg;
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), 3000);
      }

      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const name = document.getElementById('name').value;
        const email = document.getElementById('email').value;
        const subject = document.getElementById('subject').value || 'Inquiry';
        const message = document.getElementById('message').value;

        const body = `NAME: ${name}\nEMAIL: ${email}\n\nMESSAGE:\n${message}`;
        window.location.href = `mailto:${SUPPORT_EMAIL}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
        
        showToast('OPENING EMAIL CLIENT');
      });

      copyBtn.addEventListener('click', () => {
        navigator.clipboard.writeText(SUPPORT_EMAIL).then(() => {
          showToast('EMAIL COPIED TO CLIPBOARD');
        });
      });
    </script>
  </body>
</html>