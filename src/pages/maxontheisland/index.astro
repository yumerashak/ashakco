---
import Header from "../../components/company/CompanyHeader.astro";
import Footer from "../../components/company/CompanyFooter.astro";

/** YouTube trailer ID (ID only) */
const trailerId = "uFnMAWKRzus";

/** Feature content - Metinler aynı tutuldu */
interface Section {
  img: string;
  title: string;
  text: string;
  tag: string;
}

const sections: Section[] = [
  {
    img: "/assets/screenshot-4.png",
    title: "PLAY ANYWHERE",
    text: "Tablet, phone… playable on every device. Original visuals and a user-friendly design optimized for touch controls.",
    tag: "SEAMLESS CROSS-PLATFORM"
  },
  {
    img: "/assets/screenshot-3.PNG",
    title: "ESCAPE THE ISLAND",
    text: "Max is stranded. The Island is full of mysteries, traps, and puzzles. Help him escape. Every level is a new adventure.",
    tag: "SURVIVAL & LOGIC"
  },
  {
    img: "/assets/screenshot-2.PNG",
    title: "PROGRESS WITH HINTS",
    text: "Stuck on a puzzle? Hints point you in the right direction. Timing, reflexes, and smart decisions matter.",
    tag: "MASTER THE MECHANICS"
  },
  {
    img: "/assets/screenshot-1.PNG",
    title: "GLOBAL EXPERIENCE",
    text: "A fantastic experience in 82 languages. Play in your native language, no matter where you are.",
    tag: "NO LANGUAGE BARRIERS"
  }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MAX ON THE ISLAND | ASHAK STUDIOS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;700;800&display=swap" rel="stylesheet">

    <style>
      :root {
        --color-bg: #000000;
        --color-text: #FFFFFF;
        --color-muted: #888888;
        --color-border: #222222;
      }

      body {
        margin: 0;
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: 'Raleway', sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 40px;
      }

      /* --- HERO --- */
      .hero {
        padding: 160px 0 100px;
      }

      .app-icon {
        width: 100px; height: 100px;
        border-radius: 20px;
        margin-bottom: 30px;
        border: 1px solid #333;
      }

      .hero h1 {
        font-size: clamp(60px, 10vw, 120px);
        font-weight: 800;
        line-height: 0.9;
        letter-spacing: -4px;
        margin: 0 0 40px;
        text-transform: uppercase;
      }

      .stores {
        display: flex;
        gap: 20px;
        margin-bottom: 60px;
      }

      .store-link img {
        height: 40px;
        filter: grayscale(1) invert(1);
        transition: opacity 0.3s;
      }
      .store-link:hover img { opacity: 0.7; }

      /* VIDEO */
      .video-wrapper {
        width: 100%;
        max-width: 1000px;
        border: 1px solid var(--color-border);
        padding: 12px;
        background: #0A0A0A;
        border-radius: 24px;
        margin-bottom: 80px;
      }

      .video-container {
        position: relative;
        padding-bottom: 56.25%; /* 16:9 */
        height: 0;
        overflow: hidden;
        border-radius: 12px;
      }

      .video-container iframe {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        border: none;
      }

      /* --- FEATURES --- */
      .feature-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        padding: 80px 0;
        border-top: 1px solid var(--color-border);
        align-items: center;
      }

      .tag {
        font-size: 11px;
        letter-spacing: 2px;
        color: var(--color-muted);
        margin-bottom: 20px;
        display: block;
        font-weight: 700;
      }

      .feature-row h3 {
        font-size: 42px;
        font-weight: 700;
        margin: 0 0 20px;
        letter-spacing: -1px;
      }

      .feature-row p {
        font-size: 18px;
        color: var(--color-muted);
        line-height: 1.6;
        max-width: 450px;
      }

      .device-frame {
        width: 100%;
        max-width: 600px;
        border: 1px solid #333;
        border-radius: 12px;
        padding: 8px;
        background: #0a0a0a;
        margin-left: auto;
      }

      .device-frame img {
        width: 100%;
        border-radius: 6px;
        display: block;
      }

      @media (max-width: 900px) {
        .feature-row { grid-template-columns: 1fr; gap: 40px; }
        .hero h1 { letter-spacing: -2px; }
        .device-frame { margin-left: 0; }
        .container { padding: 0 20px; }
      }
    </style>
  </head>
  <body>
    <Header />

    <main class="container">
      <section class="hero">
        <img src="/assets/maxontheislandlogo.png" alt="Max" class="app-icon" />
        <h1>MAX ON THE<br/>ISLAND</h1>
        <div class="stores">
          <a href="#" class="store-link"><img src="/assets/appstore.png" alt="App Store" /></a>
          <a href="#" class="store-link"><img src="/assets/googleplay.png" alt="Play Store" /></a>
        </div>

        <div class="video-wrapper">
          <div class="video-container">
            <iframe
              src={`https://www.youtube.com/embed/${trailerId}?rel=0&modestbranding=1`}
              title="Trailer"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      </section>

      <section class="features">
        {sections.map((s) => (
          <div class="feature-row">
            <div class="text-content">
              <span class="tag">{s.tag}</span>
              <h3>{s.title}</h3>
              <p>{s.text}</p>
            </div>
            <div class="img-container">
              <div class="device-frame">
                <img src={s.img} alt={s.title} />
              </div>
            </div>
          </div>
        ))}
      </section>
    </main>

    <Footer />
  </body>
</html>