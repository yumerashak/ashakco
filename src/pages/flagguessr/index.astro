---
import Header from "../../components/company/CompanyHeader.astro";
import Footer from "../../components/company/CompanyFooter.astro";

/** Feature content - Metinler aynı tutuldu */
interface Section {
  img: string;
  title: string;
  text: string;
  tag: string;
}

const sections: Section[] = [
  {
    img: "/assets/flagguessr-ss-1.jpg",
    title: "FLAG & MAP COMBO",
    text: "It's not just a flag quiz. See the country's border shape on a real map, watch the pin drop, and use the emoji flag to guess the nation.",
    tag: "DUAL VISUALS"
  },
  {
    img: "/assets/flagguessr-ss-2.jpg",
    title: "UNSCRAMBLE THE NAME",
    text: "Test your spelling. You are given a scrambled keyboard of letters. Tap to place them in the correct order and reveal the country's name.",
    tag: "WORD PUZZLE"
  },
  {
    img: "/assets/flagguessr-ss-3.jpg",
    title: "SMART HINTS",
    text: "Stuck on a tricky island nation? Use hints to reveal the correct letters in the box. Solve the puzzle without breaking your flow.",
    tag: "LIFELINES"
  },
  {
    img: "/assets/flagguessr-ss-4.jpg",
    title: "MASTER THE GLOBE",
    text: "Track your progress as you turn the world map green. Compete on global leaderboards and complete your collection of known countries.",
    tag: "PROGRESSION"
  }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FLAGGUESSR | ASHAK STUDIOS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;700;800&display=swap" rel="stylesheet">

    <style>
      :root {
        --color-bg: #000000;
        --color-text: #FFFFFF;
        --color-muted: #888888;
        --color-border: #222222;
      }

      body {
        margin: 0;
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: 'Raleway', sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 40px;
      }

      /* --- HERO --- */
      .hero {
        padding: 160px 0 100px;
      }

      .app-icon {
        width: 100px; height: 100px;
        border-radius: 20px;
        margin-bottom: 30px;
        border: 1px solid #333;
      }

      .hero h1 {
        font-size: clamp(60px, 10vw, 120px);
        font-weight: 800;
        line-height: 0.9;
        letter-spacing: -4px;
        margin: 0 0 40px;
        text-transform: uppercase;
      }

      .kicker {
        font-size: 20px;
        color: var(--color-muted);
        max-width: 600px;
        margin-bottom: 40px;
        font-weight: 300;
      }

      .stores {
        display: flex;
        gap: 20px;
      }

      .store-link img {
        height: 40px;
        filter: grayscale(1) invert(1);
        transition: opacity 0.3s;
      }
      .store-link:hover img { opacity: 0.7; }

      /* --- FEATURES --- */
      .feature-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        padding: 80px 0;
        border-top: 1px solid var(--color-border);
        align-items: center;
      }

      .tag {
        font-size: 11px;
        letter-spacing: 2px;
        color: var(--color-muted);
        margin-bottom: 20px;
        display: block;
        font-weight: 700;
      }

      .feature-row h3 {
        font-size: 42px;
        font-weight: 700;
        margin: 0 0 20px;
        letter-spacing: -1px;
      }

      .feature-row p {
        font-size: 18px;
        color: var(--color-muted);
        line-height: 1.6;
        max-width: 450px;
      }

      .device-frame {
        width: 100%;
        max-width: 340px;
        border: 1px solid #333;
        border-radius: 40px;
        padding: 12px;
        background: #0a0a0a;
        margin-left: auto;
      }

      .device-frame img {
        width: 100%;
        border-radius: 30px;
        display: block;
      }

      @media (max-width: 900px) {
        .feature-row { grid-template-columns: 1fr; gap: 40px; }
        .hero h1 { letter-spacing: -2px; }
        .device-frame { margin-left: 0; }
        .container { padding: 0 20px; }
      }
    </style>
  </head>
  <body>
    <Header />

    <main class="container">
      <section class="hero">
        <img src="/assets/flagguessr-icon.png" alt="FlagGuessr" class="app-icon" />
        <h1>FLAGGUESSR</h1>
        <p class="kicker">Know the Flag • Name the Country</p>
        <div class="stores">
          <a href="#" class="store-link"><img src="/assets/appstore.png" alt="App Store" /></a>
          <a href="#" class="store-link"><img src="/assets/googleplay.png" alt="Play Store" /></a>
        </div>
      </section>

      <section class="features">
        {sections.map((s) => (
          <div class="feature-row">
            <div class="text-content">
              <span class="tag">{s.tag}</span>
              <h3>{s.title}</h3>
              <p>{s.text}</p>
            </div>
            <div class="img-container">
              <div class="device-frame">
                <img src={s.img} alt={s.title} />
              </div>
            </div>
          </div>
        ))}
      </section>
    </main>

    <Footer />
  </body>
</html>