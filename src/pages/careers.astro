---
import Header from "../components/company/CompanyHeader.astro";
import Footer from "../components/company/CompanyFooter.astro";

const roles = [
  {
    id: "swift-developer",
    title: "SWIFTUI ENGINEER",
    department: "ENGINEERING",
    location: "REMOTE",
    type: "FULL-TIME",
    summary:
      "SwiftUI, Swift Concurrency, MVVM, SwiftData, Localization, Observation Framework, StoreKit 2, Performance Profiling.",
  },
  {
    id: "product-designer",
    title: "PRODUCT DESIGNER",
    department: "DESIGN",
    location: "REMOTE",
    type: "FULL-TIME",
    summary:
      "Figma, Apple HIG, Design Systems, Minimalist UI/UX, Motion Design, Prototyping, Asset Optimization, Accessibility Standards.",
  },
  {
    id: "systems-architect",
    title: "SYSTEMS ARCHITECT",
    department: "INFRASTRUCTURE",
    location: "REMOTE",
    type: "FULL-TIME",
    summary:
      "Local-first Architecture, E2E Encryption, Database Optimization, AI Model Integration, Cloud Sync Protocols, DevOps, Infrastructure as Code.",
  },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CAREERS | ASHAK STUDIOS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;700;800&display=swap" rel="stylesheet">

    <style>
      :root {
        --color-bg: #000000;
        --color-text: #FFFFFF;
        --color-muted: #888888;
        --color-border: #333333;
      }

      body {
        margin: 0;
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: 'Raleway', sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      .main-content {
        padding: 160px 40px 100px;
        max-width: 1400px;
        margin: 0 auto;
      }

      .hero-title {
        font-size: clamp(60px, 10vw, 120px);
        font-weight: 800;
        line-height: 0.9;
        letter-spacing: -4px;
        margin-bottom: 20px;
        text-transform: uppercase;
      }

      .section-label {
        font-size: 24px;
        font-weight: 300;
        color: var(--color-muted);
        margin-bottom: 80px;
        display: block;
      }

      .roles-list {
        display: grid;
        grid-template-columns: 1fr;
      }

      .role-item {
        border-top: 1px solid var(--color-border);
        padding: 60px 0;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 40px;
        text-decoration: none;
        color: inherit;
        transition: border-color 0.3s;
      }

      .role-item:hover {
        border-top-color: #FFF;
      }

      .role-meta {
        display: flex;
        flex-direction: column;
        gap: 8px;
      }

      .role-tag {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 2px;
        color: var(--color-muted);
        text-transform: uppercase;
      }

      .role-name {
        font-size: 36px;
        font-weight: 700;
        letter-spacing: -1px;
        margin-bottom: 12px;
        text-transform: uppercase;
      }

      .role-info {
        font-size: 12px;
        letter-spacing: 1px;
        color: var(--color-muted);
        text-transform: uppercase;
      }

      .role-description {
        font-size: 15px;
        color: var(--color-muted);
        line-height: 1.8;
        max-width: 500px;
        font-weight: 400;
        letter-spacing: 0.5px;
      }

      .role-actions {
        margin-top: 30px;
        display: flex;
        gap: 24px;
      }

      .btn-text {
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 1px;
        color: #FFF;
        text-decoration: none;
        border-bottom: 1px solid #FFF;
        text-transform: uppercase;
        cursor: pointer;
        padding-bottom: 2px;
        transition: opacity 0.3s;
      }

      .btn-text:hover {
        opacity: 0.5;
      }

      .culture-section {
        margin-top: 120px;
        padding: 80px 0;
        border-top: 1px solid var(--color-border);
      }

      .culture-title {
        font-size: 24px;
        font-weight: 300;
        margin-bottom: 40px;
        color: var(--color-muted);
      }

      .culture-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 40px;
      }

      .culture-box h4 {
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 1px;
        margin-bottom: 16px;
        text-transform: uppercase;
      }

      .culture-box p {
        font-size: 14px;
        color: var(--color-muted);
        line-height: 1.5;
      }

      @media (max-width: 900px) {
        .role-item { grid-template-columns: 1fr; padding: 40px 0; }
        .hero-title { letter-spacing: -2px; }
        .main-content { padding: 120px 20px 60px; }
      }
    </style>
  </head>
  <body>

    <Header />

    <main class="main-content">
      <h1 class="hero-title">BUILDING THE<br/>NEXT FRONTIER.</h1>
      <span class="section-label">Open Roles</span>

      <div class="roles-list">
        {roles.map(role => (
          <div class="role-item">
            <div class="role-meta">
              <span class="role-tag">{role.department}</span>
              <div class="role-name">{role.title}</div>
              <div class="role-info">{role.location} / {role.type}</div>
            </div>
            <div>
              <p class="role-description">{role.summary}</p>
              <div class="role-actions">
                <a href={`mailto:contact@ashak.co?subject=APPLICATION: ${role.title}`} class="btn-text">Apply Now</a>
                <a href={`mailto:contact@ashak.co?subject=INQUIRY: ${role.title}`} class="btn-text">Inquiry</a>
              </div>
            </div>
          </div>
        ))}
      </div>

      <section class="culture-section">
        <h2 class="culture-title">Studio Culture</h2>
        <div class="culture-grid">
          <div class="culture-box">
            <h4>Precision</h4>
            <p>Surgical attention to detail in both code and aesthetics.</p>
          </div>
          <div class="culture-box">
            <h4>Ownership</h4>
            <p>Senior-led autonomous workflow with high responsibility.</p>
          </div>
          <div class="culture-box">
            <h4>Autonomy</h4>
            <p>Remote-first, asynchronous ecosystem for deep work.</p>
          </div>
          <div class="culture-box">
            <h4>Transparency</h4>
            <p>Radical honesty and architectural integrity.</p>
          </div>
        </div>
      </section>
    </main>

    <Footer />

  </body>
</html>