---
import Header from "../../components/company/CompanyHeader.astro";
import Footer from "../../components/company/CompanyFooter.astro";

/** Feature Content Interface */
interface Section {
  img: string;
  title: string;
  text: string;
  tag: string;
}

const sections: Section[] = [
  {
    img: "/assets/strux-ss-1.jpg",
    title: "TURN WORDS INTO APPS",
    text: "Describe your app idea in plain language, and watch the AI Designer build it instantly. No complex coding required to get the first version of your dream app.",
    tag: "AI DESIGNER"
  },
  {
    img: "/assets/strux-ss-2.jpg",
    title: "VISUALIZE YOUR IDEAS",
    text: "Don't just imagine it—see it. Strux renders your concepts into real screens immediately, helping you validate your UI/UX decisions before committing to development.",
    tag: "REAL-TIME VISUALIZATION"
  },
  {
    img: "/assets/strux-ss-3.jpg",
    title: "CREATE UNLIMITED APPS",
    text: "From map-based utilities to social platforms and games. Manage multiple projects simultaneously in a clean, organized workspace designed for productivity.",
    tag: "PROJECT MANAGEMENT"
  },
  {
    img: "/assets/strux-ss-4.jpg",
    title: "START FAST WITH PRO TEMPLATES",
    text: "Skip the blank canvas anxiety. Choose from a variety of professional templates like Social Media feeds or Professional Networks to jumpstart your development.",
    tag: "TEMPLATE LIBRARY"
  },
  {
    img: "/assets/strux-ss-5.jpg",
    title: "INTUITIVE STYLING. VISUAL CONTROL.",
    text: "Fine-tune every detail without touching code. Adjust typography, font weights, colors, and alignment using a powerful visual editor that gives you total control.",
    tag: "VISUAL EDITOR"
  },
  {
    img: "/assets/strux-ss-6.jpg",
    title: "60+ POWERFUL UI COMPONENTS",
    text: "Access a massive library of native iOS components. Drag and drop Maps, Video Players, Avatars, Web Views, and more to build feature-rich applications.",
    tag: "COMPONENT LIBRARY"
  }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>STRUX | ASHAK STUDIOS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;700;800&display=swap" rel="stylesheet">

    <style>
      :root {
        --color-bg: #000000;
        --color-text: #FFFFFF;
        --color-muted: #888888;
        --color-border: #222222;
      }

      body {
        margin: 0;
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: 'Raleway', sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 40px;
      }

      /* --- HERO --- */
      .hero {
        padding: 160px 0 100px;
      }

      .app-icon {
        width: 100px; height: 100px;
        border-radius: 20px;
        margin-bottom: 30px;
        border: 1px solid #333;
      }

      .hero h1 {
        font-size: clamp(60px, 10vw, 120px);
        font-weight: 800;
        line-height: 0.9;
        letter-spacing: -4px;
        margin: 0 0 40px;
        text-transform: uppercase;
      }

      .kicker {
        font-size: 20px;
        color: var(--color-muted);
        max-width: 600px;
        margin-bottom: 40px;
        font-weight: 300;
      }

      .store-link img {
        height: 40px;
        filter: grayscale(1) invert(1);
        transition: opacity 0.3s;
      }
      .store-link:hover img { opacity: 0.7; }

      /* --- FEATURES --- */
      .feature-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        padding: 80px 0;
        border-top: 1px solid var(--color-border);
        align-items: center;
      }

      .tag {
        font-size: 11px;
        letter-spacing: 2px;
        color: var(--color-muted);
        margin-bottom: 20px;
        display: block;
        font-weight: 700;
      }

      .feature-row h3 {
        font-size: 42px;
        font-weight: 700;
        margin: 0 0 20px;
        letter-spacing: -1px;
      }

      .feature-row p {
        font-size: 18px;
        color: var(--color-muted);
        line-height: 1.6;
        max-width: 450px;
      }

      .device-frame {
        width: 100%;
        max-width: 340px;
        border: 1px solid #333;
        border-radius: 40px;
        padding: 12px;
        background: #0a0a0a;
        margin-left: auto;
      }

      .device-frame img {
        width: 100%;
        border-radius: 30px;
        display: block;
      }

      @media (max-width: 900px) {
        .feature-row { grid-template-columns: 1fr; gap: 40px; }
        .hero h1 { letter-spacing: -2px; }
        .device-frame { margin-left: 0; }
        .container { padding: 0 20px; }
      }
    </style>
  </head>
  <body>
    <Header />

    <main class="container">
      <section class="hero">
        <img src="/assets/strux-icon.png" alt="Strux" class="app-icon" />
        <h1>TURN WORDS INTO<br/>NATIVE APPS.</h1>
        <p class="kicker">
          The ultimate iOS app builder. Describe, visualize, and build professional apps with AI.
        </p>
        <a href="https://apps.apple.com/us/app/strux-ios-app-builder/id6756887617" class="store-link" target="_blank">
          <img src="/assets/appstore.png" alt="App Store" />
        </a>
      </section>

      <section class="features">
        {sections.map((s) => (
          <div class="feature-row">
            <div class="text-content">
              <span class="tag">{s.tag}</span>
              <h3>{s.title}</h3>
              <p>{s.text}</p>
            </div>
            <div class="img-container">
              <div class="device-frame">
                <img src={s.img} alt={s.title} />
              </div>
            </div>
          </div>
        ))}
      </section>
    </main>

    <Footer />
  </body>
</html>