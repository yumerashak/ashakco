---
import Header from "../../components/company/CompanyHeader.astro";
import Footer from "../../components/company/CompanyFooter.astro";

const sections = [
  {
    img: "/assets/countryguessr-ss-1.jpg",
    title: "REAL WORLD MAPS",
    text: "No cartoons. Explore the world through real satellite imagery and street maps. Pan, zoom, and investigate borders like a detective.",
    tag: "SATELLITE IMAGERY"
  },
  {
    img: "/assets/countryguessr-ss-2.jpg",
    title: "IDENTIFY THE NATION",
    text: "Analyze the geography. Is it a coastline? A desert? A jungle? Use your knowledge to pick the correct country from the options.",
    tag: "GEOGRAPHY QUIZ"
  },
  {
    img: "/assets/countryguessr-ss-3.jpg",
    title: "TACTICAL HINTS",
    text: "Stuck on a tough border? Unlock hints like Region, Flag, or Capital City to narrow down the possibilities.",
    tag: "STRATEGIC INTEL"
  },
  {
    img: "/assets/countryguessr-ss-4.jpg",
    title: "GLOBAL LEADERBOARD",
    text: "Build your streak. Collect every country in your passport. Compete with players worldwide for the highest geo-IQ.",
    tag: "RANK UP"
  }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>COUNTRYGUESSR | ASHAK STUDIOS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;700;800&display=swap" rel="stylesheet">

    <style>
      :root {
        --color-bg: #000000;
        --color-text: #FFFFFF;
        --color-muted: #888888;
      }

      body {
        margin: 0;
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: 'Raleway', sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 40px;
      }

      /* --- HERO --- */
      .hero {
        padding: 160px 0 100px;
      }

      .app-label {
        font-size: 14px;
        letter-spacing: 4px;
        color: var(--color-muted);
        display: block;
        margin-bottom: 20px;
        font-weight: 700;
      }

      .hero h1 {
        font-size: clamp(60px, 10vw, 120px);
        font-weight: 800;
        line-height: 0.9;
        letter-spacing: -4px;
        margin: 0 0 40px;
      }

      .stores {
        display: flex;
        gap: 20px;
      }

      .store-link img {
        height: 40px;
        filter: grayscale(1) invert(1);
        transition: opacity 0.3s;
      }
      .store-link:hover img { opacity: 0.7; }

      /* --- FEATURES --- */
      .features {
        padding-bottom: 100px;
      }

      .feature-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        padding: 80px 0;
        border-top: 1px solid #222;
        align-items: center;
      }

      .tag {
        font-size: 11px;
        letter-spacing: 2px;
        color: var(--color-muted);
        margin-bottom: 20px;
        display: block;
        font-weight: 700;
      }

      .feature-row h3 {
        font-size: 42px;
        font-weight: 700;
        margin: 0 0 20px;
        letter-spacing: -1px;
      }

      .feature-row p {
        font-size: 18px;
        color: var(--color-muted);
        line-height: 1.6;
        max-width: 450px;
      }

      .device-frame {
        width: 100%;
        max-width: 340px;
        border: 1px solid #333;
        border-radius: 40px;
        padding: 12px;
        background: #0a0a0a;
        margin-left: auto;
      }

      .device-frame img {
        width: 100%;
        border-radius: 30px;
        display: block;
      }

      @media (max-width: 900px) {
        .feature-row { grid-template-columns: 1fr; gap: 40px; }
        .hero h1 { letter-spacing: -2px; }
        .device-frame { margin-left: 0; }
      }
    </style>
  </head>
  <body>
    <Header />

    <main class="container">
      <section class="hero">
        <span class="app-label">CARTOGRAPHY SERIES</span>
        <h1>COUNTRYGUESSR</h1>
        <div class="stores">
          <a href="#" class="store-link"><img src="/assets/appstore.png" alt="App Store" /></a>
          <a href="#" class="store-link"><img src="/assets/googleplay.png" alt="Play Store" /></a>
        </div>
      </section>

      <section class="features">
        {sections.map((s) => (
          <div class="feature-row">
            <div class="text-content">
              <span class="tag">{s.tag}</span>
              <h3>{s.title}</h3>
              <p>{s.text}</p>
            </div>
            <div class="img-container">
              <div class="device-frame">
                <img src={s.img} alt={s.title} />
              </div>
            </div>
          </div>
        ))}
      </section>
    </main>

    <Footer />
  </body>
</html>