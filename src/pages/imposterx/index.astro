---
import Header from "../../components/company/CompanyHeader.astro";
import Footer from "../../components/company/CompanyFooter.astro";

/** Feature content - Metinler aynı tutuldu */
interface Section {
  img: string;
  title: string;
  text: string;
  tag: string;
}

const sections: Section[] = [
  {
    img: "/assets/imposterx-ss-1.jpg",
    title: "ROLES ASSIGNED",
    text: "One secret Imposter. The rest are Crew. The Crew gets a secret word, but the Imposter sees nothing. Let the paranoia begin.",
    tag: "TRUST NO ONE"
  },
  {
    img: "/assets/imposterx-ss-2.jpg",
    title: "GIVE CLUES",
    text: "Go around the circle. Give a one-word clue related to the secret topic. Be vague enough to hide from the Imposter, but clear enough to prove you know the word.",
    tag: "DON'T REVEAL TOO MUCH"
  },
  {
    img: "/assets/imposterx-ss-3.jpg",
    title: "SPOT THE FAKE",
    text: "The Imposter must blend in giving a clue without knowing the topic. Watch for hesitation. Listen for clues that don't quite fit.",
    tag: "ANALYZE BEHAVIOR"
  },
  {
    img: "/assets/imposterx-ss-4.jpg",
    title: "THE VOTE",
    text: "Discuss, accuse, and vote. If the Crew finds the Imposter, they win. If they vote out an innocent, the Imposter wins.",
    tag: "ELIMINATION ROUND"
  }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>IMPOSTERX | ASHAK STUDIOS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;700;800&display=swap" rel="stylesheet">

    <style>
      :root {
        --color-bg: #000000;
        --color-text: #FFFFFF;
        --color-muted: #888888;
        --color-border: #222222;
      }

      body {
        margin: 0;
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: 'Raleway', sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 40px;
      }

      /* --- HERO --- */
      .hero {
        padding: 160px 0 100px;
      }

      .app-icon {
        width: 100px; height: 100px;
        border-radius: 20px;
        margin-bottom: 30px;
        border: 1px solid #333;
      }

      .hero h1 {
        font-size: clamp(60px, 10vw, 120px);
        font-weight: 800;
        line-height: 0.9;
        letter-spacing: -4px;
        margin: 0 0 40px;
        text-transform: uppercase;
      }

      .stores {
        display: flex;
        gap: 20px;
      }

      .store-link img {
        height: 40px;
        filter: grayscale(1) invert(1);
        transition: opacity 0.3s;
      }
      .store-link:hover img { opacity: 0.7; }

      /* --- FEATURES --- */
      .feature-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        padding: 80px 0;
        border-top: 1px solid var(--color-border);
        align-items: center;
      }

      .tag {
        font-size: 11px;
        letter-spacing: 2px;
        color: var(--color-muted);
        margin-bottom: 20px;
        display: block;
        font-weight: 700;
      }

      .feature-row h3 {
        font-size: 42px;
        font-weight: 700;
        margin: 0 0 20px;
        letter-spacing: -1px;
      }

      .feature-row p {
        font-size: 18px;
        color: var(--color-muted);
        line-height: 1.6;
        max-width: 450px;
      }

      .device-frame {
        width: 100%;
        max-width: 340px;
        border: 1px solid #333;
        border-radius: 40px;
        padding: 12px;
        background: #0a0a0a;
        margin-left: auto;
      }

      .device-frame img {
        width: 100%;
        border-radius: 30px;
        display: block;
      }

      /* --- RULES --- */
      .rules-section {
        padding: 100px 0;
        border-top: 1px solid var(--color-border);
      }

      .rules-title {
        font-size: 24px;
        font-weight: 300;
        color: var(--color-muted);
        margin-bottom: 60px;
      }

      .rules-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 60px 40px;
      }

      .rule-item {
        display: flex;
        gap: 24px;
      }

      .rule-num {
        font-size: 32px;
        font-weight: 800;
        color: #333; /* Hafif silik numara */
        line-height: 1;
      }

      .rule-text {
        font-size: 16px;
        color: var(--color-muted);
        line-height: 1.6;
      }

      .rule-text strong {
        color: #FFF;
      }

      @media (max-width: 900px) {
        .feature-row { grid-template-columns: 1fr; gap: 40px; }
        .hero h1 { letter-spacing: -2px; }
        .device-frame { margin-left: 0; }
        .container { padding: 0 20px; }
      }
    </style>
  </head>
  <body>
    <Header />

    <main class="container">
      <section class="hero">
        <img src="/assets/imposterx-icon.jpg" alt="ImposterX" class="app-icon" />
        <h1>IMPOSTERX</h1>
        <div class="stores">
          <a href="#" class="store-link"><img src="/assets/appstore.png" alt="App Store" /></a>
          <a href="#" class="store-link"><img src="/assets/googleplay.png" alt="Play Store" /></a>
        </div>
      </section>

      <section class="features">
        {sections.map((s) => (
          <div class="feature-row">
            <div class="text-content">
              <span class="tag">{s.tag}</span>
              <h3>{s.title}</h3>
              <p>{s.text}</p>
            </div>
            <div class="img-container">
              <div class="device-frame">
                <img src={s.img} alt={s.title} />
              </div>
            </div>
          </div>
        ))}
      </section>

      <section class="rules-section">
        <h2 class="rules-title">GAME RULES</h2>
        <div class="rules-grid">
          <div class="rule-item">
            <div class="rule-num">01</div>
            <div class="rule-text">One player is the <strong>IMPOSTER</strong>. Everyone else is <strong>CREW</strong>.</div>
          </div>
          <div class="rule-item">
            <div class="rule-num">02</div>
            <div class="rule-text">The Crew sees a secret word. The Imposter sees nothing but must pretend they know it.</div>
          </div>
          <div class="rule-item">
            <div class="rule-num">03</div>
            <div class="rule-text">Each player says <strong>one word</strong> as a clue. Be vague enough to hide from the Imposter, but clear enough for the Crew.</div>
          </div>
          <div class="rule-item">
            <div class="rule-num">04</div>
            <div class="rule-text">The Imposter must blend in and give a clue without knowing the topic.</div>
          </div>
          <div class="rule-item">
            <div class="rule-num">05</div>
            <div class="rule-text"><strong>The Vote.</strong> If the Crew identifies the Imposter, they win. If they vote out an innocent, the Imposter wins.</div>
          </div>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>