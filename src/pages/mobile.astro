---
import Header from "../components/company/CompanyHeader.astro";
import Footer from "../components/company/CompanyFooter.astro";

const steps = [
  {
    num: "01",
    title: "STRATEGY & DISCOVERY",
    desc: "Projenizi analiz ediyor, pazar araştırması ve hedef kitle belirleme süreçlerini yönetiyoruz. Uygulamanızın temel özelliklerini ve gelir modelini bu aşamada kurguluyoruz."
  },
  {
    num: "02",
    title: "UI/UX ARCHITECTURE",
    desc: "Apple HIG ve Google Material Design standartlarında, minimalist ve kullanıcı dostu arayüzler tasarlıyoruz. Akıcı bir kullanıcı deneyimi için her pikseli titizlikle işliyoruz."
  },
  {
    num: "03",
    title: "NATIVE ENGINEERING",
    desc: "En yüksek performans için Swift (iOS) ve Kotlin (Android) kullanarak native geliştirme yapıyoruz. Cihaz donanımlarını maksimum verimlilikle optimize ediyoruz."
  },
  {
    num: "04",
    title: "QUALITY ASSURANCE",
    desc: "Farklı cihaz segmentlerinde kapsamlı stres testleri uyguluyoruz. Sıfır hata politikasıyla uygulamanın her koşulda stabil çalışmasını garanti altına alıyoruz."
  },
  {
    num: "05",
    title: "DEPLOYMENT & ASO",
    desc: "Uygulamanızı App Store ve Play Store'a yayına alıyoruz. App Store Optimization (ASO) teknikleriyle market görünürlüğünüzü ve indirme oranlarınızı artırıyoruz."
  }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MOBILE SOLUTIONS | ASHAK STUDIOS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;700;800&display=swap" rel="stylesheet">

    <style>
      :root {
        --color-bg: #000000;
        --color-text: #FFFFFF;
        --color-muted: #888888;
        --color-border: #333333;
      }

      body {
        margin: 0;
        background-color: var(--color-bg);
        color: var(--color-text);
        font-family: 'Raleway', sans-serif;
        -webkit-font-smoothing: antialiased;
      }

      .main-content {
        padding: 160px 40px 100px;
        max-width: 1400px;
        margin: 0 auto;
      }

      .hero-title {
        font-size: clamp(60px, 10vw, 120px);
        font-weight: 800;
        line-height: 0.9;
        letter-spacing: -4px;
        margin-bottom: 20px;
        text-transform: uppercase;
      }

      .section-label {
        font-size: 24px;
        font-weight: 300;
        color: var(--color-muted);
        margin-bottom: 80px;
        display: block;
      }

      .workflow-list {
        display: grid;
        grid-template-columns: 1fr;
      }

      .step-item {
        border-top: 1px solid var(--color-border);
        padding: 80px 0;
        display: grid;
        grid-template-columns: 1fr 1.5fr;
        gap: 60px;
        transition: border-color 0.3s;
      }

      .step-item:hover {
        border-top-color: #FFFFFF;
      }

      .step-num {
        font-size: 80px;
        font-weight: 800;
        color: #111; /* Çok koyu gri, sadece hover'da parlayabilir */
        line-height: 0.8;
        transition: color 0.3s;
      }

      .step-item:hover .step-num {
        color: #222;
      }

      .step-title {
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 24px;
        letter-spacing: -1px;
        text-transform: uppercase;
      }

      .step-desc {
        font-size: 18px;
        color: var(--color-muted);
        line-height: 1.6;
        max-width: 600px;
      }

      /* FINAL CTA */
      .final-cta {
        margin-top: 100px;
        padding: 100px 0;
        border-top: 1px solid var(--color-border);
      }

      .cta-text {
        font-size: 42px;
        font-weight: 700;
        margin-bottom: 40px;
        letter-spacing: -1px;
      }

      .btn-email {
        font-size: 16px;
        font-weight: 700;
        color: #FFFFFF;
        text-decoration: none;
        border-bottom: 2px solid #FFFFFF;
        padding-bottom: 4px;
        text-transform: uppercase;
        letter-spacing: 2px;
        transition: opacity 0.3s;
      }

      .btn-email:hover {
        opacity: 0.5;
      }

      @media (max-width: 900px) {
        .step-item { grid-template-columns: 1fr; gap: 20px; padding: 60px 0; }
        .hero-title { letter-spacing: -2px; }
        .main-content { padding: 120px 20px 60px; }
        .step-num { font-size: 40px; }
        .cta-text { font-size: 32px; }
      }
    </style>
  </head>
  <body>

    <Header />

    <main class="main-content">
      <h1 class="hero-title">MOBILE<br/>SOLUTIONS.</h1>
      <span class="section-label">Our Workflow</span>

      <div class="workflow-list">
        {steps.map(step => (
          <div class="step-item">
            <div class="step-num">{step.num}</div>
            <div class="step-content">
              <h2 class="step-title">{step.title}</h2>
              <p class="step-desc">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <section class="final-cta">
        <h2 class="cta-text">READY TO BUILD THE FUTURE?</h2>
        <a href="mailto:contact@ashak.co?subject=Mobile Project Inquiry" class="btn-email">
          Get a Custom Quote
        </a>
      </section>
    </main>

    <Footer />

  </body>
</html>