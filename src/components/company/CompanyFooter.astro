---
const year = new Date().getFullYear();
---
<style>
  .footer-section {
    background-color: #000;
    border-top: 1px solid #222;
    padding: 80px 40px 40px;
    font-family: 'Raleway', sans-serif;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 40px;
  }

  .brand-title {
    font-size: 20px;
    font-weight: 800;
    color: #FFF;
    margin-bottom: 16px;
  }

  .footer-desc {
    color: #666;
    font-size: 14px;
    line-height: 1.6;
    max-width: 300px;
  }

  h4 {
    color: #FFF;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 24px;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  li { margin-bottom: 12px; }

  a {
    color: #888;
    text-decoration: none;
    font-size: 13px;
    transition: color 0.3s;
  }

  a:hover { color: #FFF; }

  .bottom-bar {
    margin-top: 80px;
    padding-top: 24px;
    border-top: 1px solid #111;
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: #444;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  @media (max-width: 768px) {
    .container { grid-template-columns: 1fr; }
    .bottom-bar { flex-direction: column; gap: 10px; }
  }
</style>

<footer class="footer-section">
  <div class="container">
    <div>
      <div class="brand-title">ASHAK STUDIOS.</div>
      <p class="footer-desc">
        Next generation mobile experiences designed with surgical precision and aesthetic excellence.
      </p>
    </div>

    <div>
      <h4>Explore</h4>
      <ul>
        <li><a href="/thestudio">The Studio</a></li>
        <li><a href="/careers">Careers</a></li>
      </ul>
    </div>

    <div>
      <h4>Legal</h4>
      <ul>
        <li><a href="/legal">Privacy</a></li>
        <li><a href="/legal">Terms</a></li>
      </ul>
    </div>
  </div>

  <div class="bottom-bar">
    <span>&copy; {year} Ashak Studios Inc.</span>
    <span>Istanbul / Remote</span>
  </div>
</footer>