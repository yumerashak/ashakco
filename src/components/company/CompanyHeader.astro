<style>
  .header-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid #111;
    padding: 24px 0;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex; 
    justify-content: space-between; 
    align-items: center;
  }

  .nav-right {
    display: flex;
    gap: 32px; 
    align-items: center;
  }

  .logo-img {
    height: 36px; 
    width: auto;
    display: block;
    /* Opacity geçişini kaldırdık, sadece büyüme yumuşak olacak */
    transition: transform 0.3s ease;
  }

  .logo-img:hover { 
    /* Fare üzerine gelince logoyu %10 oranında büyütür, solma yapmaz */
    transform: scale(1.1); 
  }

  .nav-link {
    font-family: 'Raleway', sans-serif;
    font-size: 12px;
    font-weight: 700;
    color: #FFF;
    text-decoration: none;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: opacity 0.3s;
  }

  .nav-link:hover { opacity: 0.5; }

  @media (max-width: 768px) {
    .container { padding: 0 20px; }
    .nav-link { font-size: 10px; letter-spacing: 1px; }
    .nav-right { gap: 16px; } 
    .logo-img { height: 20px; } 
  }
</style>

<header class="header-wrapper">
  <div class="container">
    
    <a href="/" class="logo-link">
      <img src="/favicon.png" alt="Home" class="logo-img" />
    </a>
    
    <div class="nav-right">
      <a href="/thestudio" class="nav-link">ABOUT US</a>
      <a href="/contact" class="nav-link">CONTACT</a>
    </div>

  </div>
</header>