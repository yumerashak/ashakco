<style>
  .header-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background: rgba(0, 0, 0, 0.9);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid #111;
    padding: 24px 0;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr; /* Sol - Orta - Sağ dengesi */
    align-items: center;
  }

  .nav-link {
    font-family: 'Raleway', sans-serif;
    font-size: 12px;
    font-weight: 700;
    color: #FFF;
    text-decoration: none;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: opacity 0.3s;
  }

  .nav-link:hover { opacity: 0.5; }

  /* Hizalamalar */
  .text-left { text-align: left; }
  .text-center { text-align: center; }
  .text-right { text-align: right; }

  @media (max-width: 768px) {
    .container { padding: 0 20px; }
    .nav-link { font-size: 10px; letter-spacing: 1px; }
  }
</style>

<header class="header-wrapper">
  <div class="container">
    <a href="/" class="nav-link text-left">HOME</a>
    
    <a href="/thestudio" class="nav-link text-center">ABOUT US</a>
    
    <a href="/contact" class="nav-link text-right">CONTACT</a>
  </div>
</header>